{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": ".",
  "public": true,
  "cleanUrls": false,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/",
      "dest": "/dashboard.html"
    },
    {
      "src": "/(.*\\..*)",
      "dest": "/$1"
    },
    {
      "src": "/.*",
      "dest": "/dashboard.html"
    }
  ]
}
